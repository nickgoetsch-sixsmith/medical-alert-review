# Medical Alert Review — environment variables
#
# Copy to .env.local for local dev, and set the same keys in your Vercel
# project (Project Settings → Environment Variables) for production.

# Google Analytics 4 Measurement ID.
# REQUIRED for analytics to fire. Format: G-XXXXXXXXXX
# When set, app/layout.tsx loads gtag.js and lib/analytics.ts records
# outbound affiliate clicks. When empty, no analytics script is injected.
#
# ACTION FOR NICK: confirm a GA4 property exists for medicalalertreview.com,
# then set this value in Vercel (Production + Preview). Do NOT commit the real
# value — .env files are gitignored. A real ID is present in local .env.local
# but is not deployed unless added to Vercel env.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
